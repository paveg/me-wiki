<script is:inline type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

const isDark = document.documentElement.dataset.theme === 'dark' ||
  (document.documentElement.dataset.theme === 'auto' &&
   window.matchMedia('(prefers-color-scheme: dark)').matches);

mermaid.initialize({
  startOnLoad: false,
  theme: 'base',
  themeVariables: {
    fontFamily: 'var(--sl-font, sans-serif)',
    fontSize: '14px',
    primaryColor: isDark ? '#2a2a2a' : '#f5f5f5',
    primaryBorderColor: isDark ? '#555' : '#ccc',
    primaryTextColor: isDark ? '#ddd' : '#222',
    lineColor: isDark ? '#666' : '#999',
    secondaryColor: isDark ? '#1f1f1f' : '#fafafa',
    tertiaryColor: isDark ? '#1a1a1a' : '#f0f0f0',
    background: isDark ? '#111' : '#fff',
    mainBkg: isDark ? '#2a2a2a' : '#f5f5f5',
    nodeBorder: isDark ? '#555' : '#ccc',
    clusterBkg: isDark ? '#1a1a1a' : '#f8f8f8',
    clusterBorder: isDark ? '#444' : '#ddd',
    edgeLabelBackground: isDark ? '#111' : '#fff',
  },
});

function renderDiagrams() {
  const blocks = document.querySelectorAll('.expressive-code pre[data-language="mermaid"]');
  for (const pre of blocks) {
    const wrapper = pre.closest('.expressive-code');
    if (!wrapper) continue;

    // Expressive Code stores clean source in copy button's data-code attribute.
    // It uses \x7f (DEL) as line separator instead of \n.
    const copyBtn = wrapper.querySelector('button[data-code]');
    const source = copyBtn
      ? copyBtn.getAttribute('data-code').replaceAll('\x7f', '\n')
      : pre.textContent || '';

    const container = document.createElement('div');
    container.classList.add('mermaid');
    container.textContent = source;
    wrapper.replaceWith(container);
  }
  mermaid.run();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', renderDiagrams);
} else {
  renderDiagrams();
}
document.addEventListener('astro:page-load', renderDiagrams);
</script>

{
	"config": {
		"default": true,
		// Allow long lines in wiki content
		"MD013": false,
		// Allow multiple headings with same content (e.g., "概要" in different sections)
		"MD024": { "siblings_only": true },
		// Allow inline HTML (Mermaid, KaTeX)
		"MD033": false,
		// Allow bare URLs
		"MD034": false,
		// First line can be frontmatter, not heading
		"MD041": false,
		// Allow compact table pipe style (KaTeX in tables)
		"MD060": false
	},
	"globs": ["src/content/docs/**/*.md"]
}
